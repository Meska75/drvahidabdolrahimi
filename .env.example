# نمونه فایل تنظیمات — روی سرور این فایل را با مقادیر واقعی کپی کنید به نام .env

# یک کلید تصادفی امن تولید کنید:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-strong-secret-key-here

# در پروداکشن حتماً False باشد
DEBUG=False

# دامنه‌های مجاز (بدون https:// و بدون /)
# مثال: drvahidabdolrahimi.com,www.drvahidabdolrahimi.com
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
